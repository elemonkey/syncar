
# ===== CONFIGURACIÓN GENERAL Y DE VERSIÓN =====
# Nombre del proyecto para Docker Compose, evita colisiones.
COMPOSE_PROJECT_NAME=syncar
# Versión de la aplicación. Se inyecta automáticamente en el CI/CD.
APP_VERSION=local-dev

# ===== CONFIGURACIÓN DE ENTORNO DE PRODUCCIÓN =====
# Dominio principal donde correrá la aplicación.
DOMAIN_NAME=syncar.cl
# IP del servidor de producción.
SERVER_IP=45.14.194.85

# ===== CONFIGURACIÓN DE POSTGRESQL =====
# Asegúrate de usar contraseñas seguras en producción.
POSTGRES_DB=importapp_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=supersecretpassword
DATABASE_URL=postgresql://admin:supersecretpassword@postgres:5432/importapp_db

# ===== CONFIGURACIÓN DE REDIS =====
# URL de conexión para Celery.
REDIS_URL=redis://redis:6379/0

# ===== CONFIGURACIÓN DEL BACKEND (FastAPI) =====
# Clave secreta para firmar tokens JWT. Generar una clave larga y aleatoria.
SECRET_KEY=un-secreto-muy-largo-y-aleatorio-para-tokens
# URL del frontend para la configuración de CORS.
FRONTEND_URL=https://syncar.cl

# ===== CONFIGURACIÓN DEL FRONTEND (Next.js) =====
# En producción, Nginx redirigirá /api, por lo que la URL puede ser relativa.
NEXT_PUBLIC_API_URL=/api/v1
# Se expone la versión de la app al cliente.
NEXT_PUBLIC_APP_VERSION=${APP_VERSION}

# ===== CREDENCIALES DE IMPORTADORES =====
# Estas credenciales deben ser manejadas como secretos en producción.
ALSACIA_USERNAME=user_alsacia
ALSACIA_PASSWORD=pass_alsacia
REFAX_USERNAME=user_refax
REFAX_PASSWORD=pass_refax
NORIEGA_USERNAME=user_noriega
NORIEGA_PASSWORD=pass_noriega
EMASA_USERNAME=user_emasa
EMASA_PASSWORD=pass_emasa
